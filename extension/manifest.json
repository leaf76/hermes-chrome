{
  "manifest_version": 3,
  "name": "Hermes Chrome",
  "version": "1.2.1",
  "description": "Make Chrome easy for Hermes and local AI agents—workspace, optional tab capture, less focus-stealing, local CLI bridge only.",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:19876/*",
    "http://localhost:19876/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Hermes Chrome",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "114"
}
